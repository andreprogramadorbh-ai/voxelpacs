{
    "name": "voxel/bi",
    "description": "VOXEL B.I — Plataforma de Business Intelligence para Radiologia (Multi-Tenant)",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": "^8.1",
        "vlucas/phpdotenv": "^5.5",
        "phpoffice/phpspreadsheet": "^1.29"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true
    }
}
