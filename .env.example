# ============================================================
# VOXEL PACS — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Aplicação
APP_NAME="VOXEL PACS"
APP_ENV=production
APP_URL=https://pacs.voxel.com.br
APP_DEBUG=false
SESSION_TIMEOUT=3600

# Banco de Dados
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=voxel_pacs
DB_USERNAME=voxelpacs_user
DB_PASSWORD=senha_segura_aqui

# Segurança
APP_SECRET=chave_secreta_32_chars_aqui

# SLA Padrão (minutos)
SLA_URGENCIA_MINUTOS=60
SLA_ROTINA_MINUTOS=240

# E-mail
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@voxelpacs.com.br
MAIL_FROM_NAME="VOXEL PACS"

# Armazenamento
STORAGE_PATH=/var/www/voxel-pacs/storage
UPLOAD_MAX_SIZE=50M

# ============================================================
# ORTHANC PACS Server
# ============================================================
ORTHANC_URL=http://localhost:8042
ORTHANC_USER=admin
ORTHANC_PASS=orthanc
ORTHANC_AE_TITLE=VOXELPACS
ORTHANC_DICOM_PORT=4242

# Viewer DICOM (OHIF, Weasis, etc.)
DICOM_VIEWER_URL=http://localhost:3000

# ============================================================
# Credenciais Padrão (alterar após primeiro acesso)
# ============================================================
# Superadmin:
#   E-mail : admin@voxelpacs.com.br
#   Senha  : Admin259087@
