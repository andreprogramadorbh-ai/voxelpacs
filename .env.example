# ============================================================
# VOXEL B.I — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores
# ============================================================

# Aplicação
APP_NAME="VOXEL B.I"
APP_ENV=production
APP_URL=https://bi.voxel.com.br
APP_DEBUG=false
SESSION_TIMEOUT=3600

# Banco de Dados
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=voxel_bi
DB_USERNAME=voxel_user
DB_PASSWORD=senha_segura_aqui

# Segurança
APP_SECRET=chave_secreta_32_chars_aqui

# SLA Padrão (minutos) — pode ser sobrescrito por tenant
SLA_URGENCIA_MINUTOS=60
SLA_ROTINA_MINUTOS=240

# E-mail (alertas e notificações)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=noreply@voxel.com.br
MAIL_FROM_NAME="VOXEL B.I"

# Armazenamento
STORAGE_PATH=/var/www/voxel-bi/storage
UPLOAD_MAX_SIZE=50M

# Integração ERP VOXEL (opcional)
VOXEL_ERP_API_URL=
VOXEL_ERP_API_TOKEN=
